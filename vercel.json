{
  "buildCommand": "npx puppeteer browsers install chrome && npm run build",
  "redirects": [
    { "source": "/index.php/enfriadores-evaporativos-de-techo-bio-cool/:path*", "destination": "/soluciones/climatizacion/evaporativo", "permanent": true },
    { "source": "/index.php/enfriadores-evaporativos-de-pared-cool-space/:path*", "destination": "/soluciones/climatizacion/evaporativo", "permanent": true },
    { "source": "/index.php/ventiladores-industriales/:path*", "destination": "/soluciones/climatizacion/ventilacion", "permanent": true },
    { "source": "/index.php/consultoria-en-eficiencia-operativa/:path*", "destination": "/consultoria", "permanent": true },
    { "source": "/index.php/contacto/:path*", "destination": "/#contacto", "permanent": true },
    { "source": "/index.php/preserveair/:path*", "destination": "/soluciones/climatizacion/evaporativo", "permanent": true },
    { "source": "/index.php/:path*", "destination": "/", "permanent": true }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "SAMEORIGIN" }
      ]
    },
    {
      "source": "/casos",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }]
    },
    {
      "source": "/consultoria",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }]
    },
    {
      "source": "/articulos",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }]
    },
    {
      "source": "/articulos/:path*",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }]
    },
    {
      "source": "/soluciones/:path*",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }]
    }
  ],
  "rewrites": [
    { "source": "/((?!assets|catalogos|favicon|robots|sitemap|llms|og-image|apple-touch).*)", "destination": "/index.html" }
  ]
}
